<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="com.callwave.flutter.methodchannel">

  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
  <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

  <application>
    <receiver
      android:name=".receiver.CallActionReceiver"
      android:exported="false" />

    <activity
      android:name=".activity.FullScreenCallActivity"
      android:excludeFromRecents="true"
      android:exported="false"
      android:launchMode="singleTop"
      android:showWhenLocked="true"
      android:taskAffinity=""
      android:theme="@style/CallwaveFullScreenTheme"
      android:turnScreenOn="true" />

    <activity
      android:name=".activity.ValidatedAcceptBridgeActivity"
      android:excludeFromRecents="true"
      android:exported="false"
      android:finishOnTaskLaunch="true"
      android:launchMode="singleTop"
      android:taskAffinity=""
      android:theme="@style/CallwaveBridgeTheme" />

    <service
      android:name=".service.CallForegroundService"
      android:foregroundServiceType="phoneCall"
      android:exported="false" />
  </application>
</manifest>
